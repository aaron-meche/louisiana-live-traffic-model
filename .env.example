# ── Server ────────────────────────────────────────────────────────────────────
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000

# ── Database (TimescaleDB / PostgreSQL) ───────────────────────────────────────
DATABASE_URL=postgresql://la_traffic:la_traffic@localhost:5432/la_traffic

# ── 511la.org API ─────────────────────────────────────────────────────────────
# If 511la.org requires an API key, put it here. Leave blank to attempt without.
API_511LA_KEY=
API_511LA_BASE_URL=https://511la.org/api/v2

# ── Single-camera overrides ───────────────────────────────────────────────────
# Set CAMERA_SNAPSHOT_URL to the JPEG snapshot URL for the camera you want to
# process. Find these by inspecting network requests on https://511la.org/map/
#
# Example (replace with a real URL from the 511la.org map):
#   CAMERA_SNAPSHOT_URL=https://images.511la.org/cameras/12345/latest.jpg
#
CAMERA_SNAPSHOT_URL=
CAMERA_ID=

# ── Detection ─────────────────────────────────────────────────────────────────
YOLO_MODEL=yolov8n.pt
CONFIDENCE_THRESHOLD=0.4

# ── Pipeline timing ───────────────────────────────────────────────────────────
# How often to fetch a new JPEG snapshot (seconds)
SNAPSHOT_INTERVAL_SEC=2.0
# Length of each counting window (seconds) — results are saved per window
PIPELINE_WINDOW_SEC=60

# ── Frontend ──────────────────────────────────────────────────────────────────
MAPBOX_API_KEY=your_mapbox_api_key_here
